{{!< default}}

{{#post}}
<header class="page-header" style="background-color: var(--color-bg); padding: 4rem 0 3rem; text-align: center; border-bottom: none;">
    <div class="container" style="max-width: 1200px;">
        <span style="display: inline-block; padding: 6px 14px; background: rgba(0, 126, 194, 0.1); color: var(--color-brand); border-radius: 20px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.75rem;">Corporate CSR</span>
        <h1 class="page-title" style="font-family: var(--font-heading); font-size: clamp(1.8rem, 2.5vw, 2.4rem); color: var(--color-dark); margin: 0; line-height: 1.1; letter-spacing: -0.02em;">{{title}}</h1>
        {{#if custom_excerpt}}
            <p class="page-description" style="font-size: 1.05rem; color: var(--color-text-muted); margin: 1rem auto 0; max-width: 700px; line-height: 1.6;">
                {{custom_excerpt}}
            </p>
        {{else}}
            <p class="page-description" style="font-size: 1.05rem; color: var(--color-text-muted); margin: 1rem auto 0; max-width: 700px; line-height: 1.6;">
                Join hands with Voice of Needy Foundation to empower persons with disabilities and build an inclusive workforce.
            </p>
        {{/if}}
    </div>
</header>

{{#if feature_image}}
<figure class="page-feature-image global-edge-image" style="width: 100%; margin: 0; display: block; position: relative;">
    <img src="{{img_url feature_image size="xl"}}" alt="{{title}}" style="width: 100%; height: 50vh; min-height: 400px; max-height: 550px; object-fit: cover; display: block;" />
</figure>
{{/if}}

<main id="site-main" class="site-main" style="padding: 4rem 0; background-color: #FAFAFA;">
    <div class="container" style="max-width: 1200px;">

        <div class="post-content custom-content-block" style="background: #FFF; padding: 2.5rem 3rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); font-size: 1.15rem; line-height: 1.8; color: var(--color-text);">
            {{content}}
            
            <div class="about-footer-cta" style="margin-top: 1rem; padding-top: 2rem; border-top: 1px solid #EAEAEA; text-align: center;">
                <h3 style="font-family: var(--font-heading); font-size: 2rem; color: #1C1C1C; margin-bottom: 0.5rem;">Ready to make an impact?</h3>
                <div style="width: 60px; height: 3px; background-color: #FF66A3; margin: 0 auto 1.5rem;"></div>
                <p style="color: #4A4A4A; margin-bottom: 2rem; font-size: 1.1rem;">Contact our partnership team directly to discuss CSR opportunities.</p>
                <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                    <a href="mailto:voiceofneedyfoundation2013@gmail.com" class="gh-btn" style="background-color: #007ec2; color: #FFF; padding: 12px 28px; border-radius: 50px; text-decoration: none; font-weight: 600; display: inline-block;">Email Partnership Team</a>
                </div>
            </div>
        </div>
        
    </div>
</main>
{{/post}}
