{{!< default}}

{{#post}}
<main class="site-main">
    <article class="article {{post_class}}">
        <header class="post-hero-juniper">
            <div class="post-juniper-content">
                <div class="post-tags">
                    {{#foreach tags limit="1"}}
                        <a href="{{url}}" class="tag-pill accent-pill">{{name}}</a>
                    {{/foreach}}
                </div>
                <h1 class="post-title">{{title}}</h1>
                {{#if custom_excerpt}}
                <p class="post-excerpt">{{custom_excerpt}}</p>
                {{/if}}
                <div class="post-meta">
                    {{#if primary_author.profile_image}}
                        <img src="{{primary_author.profile_image}}" alt="{{primary_author.name}}" class="author-avatar" />
                    {{/if}}
                    <span class="author-name">{{primary_author.name}}</span>
                    <span class="meta-sep">&bull;</span>
                    <time class="post-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>
                </div>
            </div>
            {{#if feature_image}}
            <div class="post-juniper-image">
                <img src="{{img_url feature_image size="xl"}}" alt="{{title}}" />
            </div>
            {{/if}}
        </header>

        <div class="post-juniper-layout">
            <aside class="post-juniper-share">
                <span class="share-label">Share</span>
                <a href="https://twitter.com/intent/tweet?text={{encode title}}&amp;url={{url absolute="true"}}" target="_blank" rel="noopener" class="share-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="w-5 h-5"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </a>
                <a href="https://www.facebook.com/sharer.php?u={{url absolute="true"}}" target="_blank" rel="noopener" class="share-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </a>
                <a href="https://www.linkedin.com/shareArticle?mini=true&url={{url absolute="true"}}&title={{encode title}}" target="_blank" rel="noopener" class="share-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path><circle cx="4" cy="4" r="2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></circle></svg>
                </a>
            </aside>

            <div class="page-content">
                {{content}}
            </div>

            <aside class="post-juniper-sidebar">
                <div class="sidebar-widget author-widget">
                    <h3>{{@site.title}}</h3>
                    <p>{{@site.description}}</p>
                </div>

                <div class="sidebar-widget featured-widget">
                    <h4>Featured posts</h4>
                    <div class="featured-list">
                        {{#get "posts" filter="featured:true+id:-{{id}}" limit="4" as |featured|}}
                            {{#if featured}}
                                {{#foreach featured}}
                                <a href="{{url}}" class="featured-item">
                                    {{#if feature_image}}
                                    <img src="{{img_url feature_image size="m"}}" alt="{{title}}">
                                    {{/if}}
                                    <div class="featured-item-content">
                                        <h5>{{title}}</h5>
                                        <span>{{date format="MMM DD, YYYY"}}</span>
                                    </div>
                                </a>
                                {{/foreach}}
                            {{else}}
                                <p style="color: var(--color-text-muted); font-size: 0.95rem; margin: 0;">No featured posts yet.</p>
                            {{/if}}
                        {{/get}}
                    </div>
                </div>

                <div class="sidebar-widget tags-widget">
                    <h4>Tags</h4>
                    <div class="tags-cloud">
                        {{#get "tags" limit="100" filter="visibility:public+slug:-[hero-slider,home-slider]"}}
                            {{#foreach tags}}
                            <a href="{{url}}" class="tag-pill">{{name}}</a>
                            {{/foreach}}
                        {{/get}}
                    </div>
                </div>

                <div class="sidebar-widget subscribe-widget">
                    <h4>Sign up for insights and ideas</h4>
                    <p>Subscribe to the latest news, stories, tips, and updates.</p>
                    <form data-members-form>
                        <input data-members-email type="email" placeholder="Email address" required>
                        <button type="submit" class="btn btn-primary" style="width: 100%;">Subscribe</button>
                    </form>
                </div>
            </aside>
        </div>
    </article>
</main>
{{/post}}
