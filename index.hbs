{{!< default}}

{{!-- SECTION 1 — HERO SLIDER --}}
<section class="hero-section">
    <div class="hero-slider">
        {{#get "posts" filter="tag:hero-slides" limit="5" include="tags"}}
            {{#if posts}}
                {{#foreach posts}}
                <div class="hero-slide {{#if @first}}active{{/if}}" {{#if feature_image}}style="background-image: url('{{img_url feature_image size="xl"}}');"{{/if}}>
                    <div class="hero-content">
                        <h2 class="reveal">{{title}}</h2>
                        <p class="reveal">{{excerpt}}</p>
                        <a href="{{#if canonical_url}}{{canonical_url}}{{else}}{{url}}{{/if}}" class="btn btn-primary reveal">{{#if meta_title}}{{meta_title}}{{else}}Learn More{{/if}}</a>
                    </div>
                </div>
                {{/foreach}}
                    <div class="slide-indicators">
                        {{#foreach posts}}
                        <button class="slide-dot {{#if @first}}active{{/if}}" aria-label="Go to slide {{@number}}"></button>
                        {{/foreach}}
                    </div>

            {{else}}
                {{!-- FALLBACK HERO MULTI-SLIDER --}}
                <div class="fallback-slider-wrapper" style="position: relative; overflow: hidden; height: 100vh;">
                    <div class="fallback-slides-container" id="fallbackSliderContainer" style="display: flex; height: 100%; transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);">
                        
                        <div class="fallback-hero-slide" style="min-width: 100%; height: 100%; display: flex; align-items: center; background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1469571486292-0ba58a3f068b?ixlib=rb-1.2.1&auto=format&fit=crop&w=1920&q=80') center/cover; position: relative;">
                            <div class="hero-content" style="position: relative; top: 0; transform: none; padding-top: 0;">
                                <h2 style="opacity: 1; transform: translateY(0);">From Dependence to Independence</h2>
                                <p style="opacity: 1; transform: translateY(0);">Voice of Needy Foundation empowers individuals with disabilities through education, mobility, and inclusive opportunities across India.</p>
                                <a href="#about" class="btn btn-primary" style="opacity: 1; transform: translateY(0);">Discover Our Work</a>
                            </div>
                        </div>

                        <div class="fallback-hero-slide" style="min-width: 100%; height: 100%; display: flex; align-items: center; background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1509062522246-3755977927d7?ixlib=rb-1.2.1&auto=format&fit=crop&w=1920&q=80') center/cover; position: relative;">
                            <div class="hero-content" style="position: relative; top: 0; transform: none; padding-top: 0;">
                                <h2 style="opacity: 1; transform: translateY(0);">Equipping for the Future</h2>
                                <p style="opacity: 1; transform: translateY(0);">Providing vocational training and digital literacy to ensure financial stability for youth in rural communities.</p>
                                <a href="#programs" class="btn btn-primary" style="opacity: 1; transform: translateY(0);">Our Programs</a>
                            </div>
                        </div>

                        <div class="fallback-hero-slide" style="min-width: 100%; height: 100%; display: flex; align-items: center; background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1584515933487-779824d29309?ixlib=rb-1.2.1&auto=format&fit=crop&w=1920&q=80') center/cover; position: relative;">
                            <div class="hero-content" style="position: relative; top: 0; transform: none; padding-top: 0;">
                                <h2 style="opacity: 1; transform: translateY(0);">Mobility & Healthcare</h2>
                                <p style="opacity: 1; transform: translateY(0);">Distributing customized wheelchairs, prosthetics, and running health camps across remote regions.</p>
                                <a href="#contact" class="btn btn-primary" style="opacity: 1; transform: translateY(0);">Get Involved</a>
                            </div>
                        </div>

                    </div>
                    <div class="slide-indicators" id="fallbackIndicators" style="position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); z-index: 10; display: flex; gap: 10px;">
                        <button class="slide-dot active" onclick="goToFBSlide(0)"></button>
                        <button class="slide-dot" onclick="goToFBSlide(1)"></button>
                        <button class="slide-dot" onclick="goToFBSlide(2)"></button>
                    </div>
                </div>
                <script>
                    let currentFBSlide = 0;
                    const fbContainer = document.getElementById('fallbackSliderContainer');
                    const fbDots = document.querySelectorAll('#fallbackIndicators .slide-dot');
                    function goToFBSlide(index) {
                        currentFBSlide = index;
                        fbContainer.style.transform = `translateX(-${index * 100}%)`;
                        fbDots.forEach(d => d.classList.remove('active'));
                        fbDots[index].classList.add('active');
                    }
                    setInterval(() => {
                        goToFBSlide((currentFBSlide + 1) % 3);
                    }, 5000);
                </script>
            {{/if}}
        {{/get}}
        <style>
            .hero-slide.active h2.reveal, .hero-slide.active p.reveal, .hero-slide.active a.reveal {
                opacity: 1 !important;
                transform: translateY(0) !important;
                transition-delay: 0.2s;
            }
        </style>
    </div>
</section>

{{!-- SECTION 2 — ABOUT THE ORGANIZATION (MASONRY SPLIT LAYOUT) --}}
<section class="section about-section" id="about" style="padding-top: 6rem; padding-bottom: 2rem; width: 100%; overflow: hidden; background-color: #FFFFFF;">
    <div class="container reveal" style="max-width: 1300px;">
        
        <div class="about-split-grid" style="display: grid; grid-template-columns: 1fr 1.1fr; gap: 4rem; align-items: center;">
            {{!-- Left: Masonry Images Grid --}}
            <div class="about-images-masonry" style="display: grid; grid-template-columns: 1fr 1.1fr; grid-template-rows: repeat(2, 220px); gap: 16px; width: 100%;">
                
                {{!-- Image 1: Left Tall (Children) --}}
                <div class="img-tall" style="grid-row: 1 / span 2; display: flex; align-items: center; justify-content: flex-end; padding: 3rem 0;">
                    <img src="{{#if @custom.about_image_1}}{{@custom.about_image_1}}{{else}}https://images.unsplash.com/photo-1509062522246-3755977927d7?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80{{/if}}" alt="Children Support" style="width: 90%; height: 100%; object-fit: cover; border-radius: 40px 0 0 40px; box-shadow: var(--shadow-sm);">
                </div>
                
                {{!-- Image 2: Top Right (Elderly Man) --}}
                <div class="img-top-right" style="height: 100%; width: 100%;">
                    <img src="{{#if @custom.about_image_2}}{{@custom.about_image_2}}{{else}}https://images.unsplash.com/photo-1518398046578-8cca57782e17?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80{{/if}}" alt="Elderly Support" style="width: 100%; height: 100%; object-fit: cover; border-radius: 40px 0 40px 0; box-shadow: var(--shadow-sm);">
                </div>
                
                {{!-- Image 3: Bottom Right (Healthcare/Nurses) --}}
                <div class="img-bottom-right" style="height: 100%; width: 100%;">
                    <img src="{{#if @custom.about_image_3}}{{@custom.about_image_3}}{{else}}https://images.unsplash.com/photo-1584515933487-779824d29309?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80{{/if}}" alt="Healthcare Community" style="width: 100%; height: 100%; object-fit: cover; border-radius: 40px 0 40px 0; box-shadow: var(--shadow-sm);">
                </div>

            </div>

            {{!-- Right: Typography Content (DYNAMIC) --}}
            <div class="about-typography" style="padding: 1rem 0;">
                {{#get "pages" filter="slug:home-about" limit="1"}}
                    {{#if pages}}
                        {{#foreach pages}}
                            <h2 style="font-family: var(--font-heading); font-size: clamp(2.5rem, 3.5vw, 3.2rem); color: #2C285D; line-height: 1.15; margin-bottom: 2rem; letter-spacing: -0.02em; font-weight: 700;">
                                {{title}}
                            </h2>
                            
                            <div style="width: 100%; height: 3px; background-color: #A0C863; margin-bottom: 2rem;"></div>

                            <div class="about-text" style="color: #4A4A4A; font-size: 1.05rem; line-height: 1.7; display: flex; flex-direction: column; gap: 1.25rem;">
                                {{content}}
                            </div>
                        {{/foreach}}
                    {{else}}
                        <!-- FALLBACK IF CMS PAGE NOT CREATED YET -->
                        <h2 style="font-family: var(--font-heading); font-size: clamp(2.5rem, 3.5vw, 3.2rem); color: #2C285D; line-height: 1.15; margin-bottom: 2rem; letter-spacing: -0.02em; font-weight: 700;">
                            Leading NGO in India for Healthcare, Education & Community Service
                        </h2>
                        
                        <div style="width: 100%; height: 3px; background-color: #A0C863; margin-bottom: 2rem;"></div>

                        <div class="about-text" style="color: #4A4A4A; font-size: 1.05rem; line-height: 1.7; display: flex; flex-direction: column; gap: 1.25rem;">
                            <p style="margin: 0;">For twenty-five years, Voice of Needy Foundation has been committed to providing a strong foundation that connects individuals, families and communities to their potential through empowerment, equality and empathy.</p>
                            <p style="margin: 0;"><strong>Admin Tip:</strong> Create a new Page in your Ghost Admin with the title "home-about" (so its URL slug is <code>home-about</code>) to dynamically replace this exact text!</p>
                        </div>
                    {{/if}}
                {{/get}}
            </div>

        </div>

        <style>
            @media (max-width: 1024px) {
                .about-split-grid { grid-template-columns: 1fr !important; gap: 3rem !important; }
                .about-images-masonry { grid-template-rows: repeat(2, 250px) !important; max-width: 600px; margin: 0 auto; }
            }
            @media (max-width: 600px) {
                .about-images-masonry { grid-template-rows: repeat(2, 160px) !important; gap: 12px !important; width: 100% !important; }
                .img-tall { padding: 0 !important; display: flex; align-items: stretch; justify-content: center; }
                .img-tall img { width: 100% !important; height: 100% !important; object-fit: cover !important; border-radius: 16px !important; }
                .img-top-right img, .img-bottom-right img { height: 100% !important; width: 100% !important; object-fit: cover !important; border-radius: 16px !important; }
            }
        </style>
    </div>
</section>

{{!-- SECTION 3 — MISSION & VISION (ALTERNATING VIDEO & QUOTE BLOCKS) --}}
<section class="section mission-section" id="mission" style="padding-top: 2rem; padding-bottom: 4rem; background-color: #FFFFFF;">
    <div class="container reveal" style="max-width: 1300px;">
        
        {{!-- BLOCK 1: MISSION --}}
        <div class="mission-split-block" style="display: flex; flex-wrap: wrap; gap: 1.5rem; justify-content: space-between; align-items: stretch; margin-bottom: 3rem;">
            
            {{!-- Left: Video Thumbnail --}}
            <div class="video-container" style="flex: 1; min-width: 300px; min-height: 300px; border-radius: 8px; overflow: hidden; box-shadow: var(--shadow-sm); position: relative; background-image: url('{{#if @custom.mission_image}}{{@custom.mission_image}}{{else}}https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?auto=format&fit=crop&w=1200&q=80{{/if}}'); background-size: cover; background-position: center; border: 1px solid rgba(0,0,0,0.05);">
                <div style="position: absolute; inset: 0; background-color: rgba(0,0,0,0.1);"></div>
            </div>

            {{!-- Right: Purple Mission Text --}}
            <div class="text-container" style="flex: 1; min-width: 300px; background-color: #007ec2; padding: 2.25rem 3rem; display: flex; flex-direction: column; justify-content: center; position: relative; color: #FFFFFF; border-radius: 8px; box-shadow: var(--shadow-sm); overflow: hidden;">
                
                {{!-- Top Quotes --}}
                <div class="quote-marks" style="display: flex; gap: 8px; margin-bottom: 2rem;">
                    <div style="width: 14px; height: 36px; background-color: #FFCC00; transform: skewX(-20deg);"></div>
                    <div style="width: 14px; height: 36px; background-color: #FFCC00; transform: skewX(-20deg);"></div>
                </div>
                
                <h3 style="font-family: var(--font-heading); font-size: clamp(1rem, 1.4vw, 1.25rem); font-weight: 400; line-height: 1.6; margin: 0 0 1.5rem 0;">
                    <strong style="font-weight: 700; color: #FFFFFF; font-size: 1.15em;">Our Mission</strong><br><br>
                    Our mission is to prevent secondary deformities through targeted early intervention, empower persons with disabilities through sustainable employment, and collaborate with institutions to ensure disability rights.
                </h3>
                
                <p style="font-size: 0.9rem; margin: 0; color: #FFFFFF; font-weight: 600;">Team Voice of Needy Foundation</p>

                {{!-- Bottom Quotes --}}
                <div class="quote-marks" style="display: flex; gap: 8px; position: absolute; bottom: 40px; right: 40px;">
                    <div style="width: 14px; height: 36px; background-color: #FFCC00; transform: skewX(-20deg);"></div>
                    <div style="width: 14px; height: 36px; background-color: #FFCC00; transform: skewX(-20deg);"></div>
                </div>
            </div>

        </div>

        {{!-- BLOCK 2: VISION --}}
        <div class="mission-split-block vision-block" style="display: flex; flex-wrap: wrap; flex-direction: row-reverse; gap: 1.5rem; justify-content: space-between; align-items: stretch; margin-bottom: 3rem;">
            
            {{!-- Right: Video Thumbnail --}}
            <div class="video-container" style="flex: 1; min-width: 300px; min-height: 300px; border-radius: 8px; overflow: hidden; box-shadow: var(--shadow-sm); position: relative; background-image: url('{{#if @custom.vision_image}}{{@custom.vision_image}}{{else}}https://images.unsplash.com/photo-1576085898323-218337e3e43c?auto=format&fit=crop&w=1200&q=80{{/if}}'); background-size: cover; background-position: center; border: 1px solid rgba(0,0,0,0.05);">
                <div style="position: absolute; inset: 0; background-color: rgba(0,0,0,0.2);"></div>
            </div>

            {{!-- Left: Purple Vision Text --}}
            <div class="text-container" style="flex: 1; min-width: 300px; background-color: #007ec2; padding: 2.25rem 3rem; display: flex; flex-direction: column; justify-content: center; position: relative; color: #FFFFFF; border-radius: 8px; box-shadow: var(--shadow-sm); overflow: hidden;">
                
                {{!-- Top Quotes --}}
                <div class="quote-marks" style="display: flex; gap: 8px; margin-bottom: 2rem;">
                    <div style="width: 14px; height: 36px; background-color: #FFCC00; transform: skewX(-20deg);"></div>
                    <div style="width: 14px; height: 36px; background-color: #FFCC00; transform: skewX(-20deg);"></div>
                </div>
                
                <h3 style="font-family: var(--font-heading); font-size: clamp(1rem, 1.4vw, 1.25rem); font-weight: 400; line-height: 1.6; margin: 0 0 1.5rem 0;">
                    <strong style="font-weight: 700; color: #FFFFFF; font-size: 1.15em;">Our Vision</strong><br><br>
                    Every person with a disability is entitled to lead a quality life with access to proper health, education, and sustainable livelihood support.
                </h3>
                
                <p style="font-size: 0.9rem; margin: 0; color: #FFFFFF; font-weight: 600;">Team Voice of Needy Foundation</p>

                {{!-- Bottom Quotes --}}
                <div class="quote-marks" style="display: flex; gap: 8px; position: absolute; bottom: 40px; right: 40px;">
                    <div style="width: 14px; height: 36px; background-color: #FFCC00; transform: skewX(-20deg);"></div>
                    <div style="width: 14px; height: 36px; background-color: #FFCC00; transform: skewX(-20deg);"></div>
                </div>
            </div>

        </div>

    </div>
</section>

{{!-- SECTION 4 — IMPACT STATS (REBUILT FOR FULL WIDTH EXACT MATCH) --}}
<section class="section impact-section" style="background-color: #FFFFFF; padding: 2rem 0; width: 100%; border-top: 1px solid #EAEAEA; border-bottom: 1px solid #EAEAEA;">
    <div class="container reveal" style="max-width: 1600px;">
        <div class="impact-stats-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; text-align: center; align-items: center;">
            
            {{!-- Stat 1 --}}
            <div class="impact-stat-item" style="padding: 2rem; position: relative;">
                <div class="stat-icon" style="width: 72px; height: 72px; border-radius: 50%; background: #EAF4DB; display: inline-flex; justify-content: center; align-items: center; margin-bottom: 1.5rem;">
                    <img src="https://i.ibb.co/Fq6qvcmg/skill.png" alt="Skill Development" style="max-width: 36px; max-height: 36px; object-fit: contain;">
                </div>
                <h3 style="font-size: clamp(2.5rem, 4vw, 3.5rem); font-weight: 800; color: #1C1C1C; font-family: var(--font-heading); margin-bottom: 0.5rem; line-height: 1; letter-spacing: -0.02em;"><span class="count-up" data-target="3000">0</span><span style="color: var(--color-accent);">+</span></h3>
                <p style="font-size: 1.15rem; color: #4A4A4A; margin: 0; font-weight: 500; padding: 0 1rem;">People impacted through Social Entitlements & Rights</p>
                <div class="stat-divider" style="position: absolute; right: 0; top: 15%; bottom: 15%; width: 1px; background-color: rgba(0,0,0,0.1);"></div>
            </div>
            
            {{!-- Stat 2 --}}
            <div class="impact-stat-item" style="padding: 2rem; position: relative;">
                <div class="stat-icon" style="width: 72px; height: 72px; border-radius: 50%; background: #EAF4DB; display: inline-flex; justify-content: center; align-items: center; margin-bottom: 1.5rem;">
                    <img src="https://i.ibb.co/QjMLbBKS/social-care.png" alt="Social Care" style="max-width: 36px; max-height: 36px; object-fit: contain;">
                </div>
                <h3 style="font-size: clamp(2.5rem, 4vw, 3.5rem); font-weight: 800; color: #1C1C1C; font-family: var(--font-heading); margin-bottom: 0.5rem; line-height: 1; letter-spacing: -0.02em;"><span class="count-up" data-target="2300">0</span><span style="color: var(--color-accent);">+</span></h3>
                <p style="font-size: 1.15rem; color: #4A4A4A; margin: 0; font-weight: 500; padding: 0 1rem;">Youth equipped with industry-relevant skills</p>
                <div class="stat-divider" style="position: absolute; right: 0; top: 15%; bottom: 15%; width: 1px; background-color: rgba(0,0,0,0.1);"></div>
            </div>
            
            {{!-- Stat 3 --}}
            <div class="impact-stat-item" style="padding: 2rem; position: relative;">
                <div class="stat-icon" style="width: 72px; height: 72px; border-radius: 50%; background: #EAF4DB; display: inline-flex; justify-content: center; align-items: center; margin-bottom: 1.5rem;">
                    <img src="https://i.ibb.co/KcTk6bWg/businessman.png" alt="Successfully placed" style="max-width: 36px; max-height: 36px; object-fit: contain;">
                </div>
                <h3 style="font-size: clamp(2.5rem, 4vw, 3.5rem); font-weight: 800; color: #1C1C1C; font-family: var(--font-heading); margin-bottom: 0.5rem; line-height: 1; letter-spacing: -0.02em;"><span class="count-up" data-target="1763">0</span><span style="color: var(--color-accent);">+</span></h3>
                <p style="font-size: 1.15rem; color: #4A4A4A; margin: 0; font-weight: 500; padding: 0 1rem;">Persons with disabilities placed in retail & service jobs</p>
            </div>
            
        </div>
    </div>
</section>

<style>
@media (max-width: 900px) {
    .impact-stats-grid { grid-template-columns: 1fr !important; gap: 3rem !important; text-align: center; }
    .stat-divider { display: none !important; }
}
</style>

{{!-- SECTION 5 — OUR PROGRAMS --}}
<section class="section programs-section" id="programs" style="padding: 2.5rem 0;">
    <div class="container" style="max-width: 1400px;">
        <div class="section-header reveal" style="text-align: center; margin-bottom: 3.5rem;">
            <h2 style="font-family: var(--font-heading); font-size: clamp(1.8rem, 3vw, 2.2rem); color: var(--color-dark); margin: 0 auto;">Our Programs</h2>
            <div style="width: 80px; height: 3px; background-color: var(--color-accent); margin: 1rem auto;"></div>
            <p style="color: var(--color-text-muted); font-size: 1.05rem; max-width: 900px; margin: 0 auto; line-height: 1.6;">At Voice of Needy, we take utmost care to serve only the highest-quality and most wholesome support to all our beneficiaries. Creating change through focused areas.</p>
            <p style="font-family: 'Caveat', cursive, serif; font-style: italic; font-weight: 700; color: var(--color-dark); font-size: 1.15rem; margin: 1rem auto 0;">Here's How The Magic Happens!</p>
        </div>
        <div class="programs-grid">
            {{#get "posts" filter="tag:programs" limit="6" include="tags" order="published_at asc"}}
                {{#if posts}}
                    {{#foreach posts}}
                        <a href="{{url}}" class="vnf-program-card">
                            {{#if feature_image}}
                                <img src="{{img_url feature_image size="m"}}" alt="{{title}}" class="vpc-image">
                            {{else}}
                                <div class="vpc-image" style="background-color: #EAF4DB;"></div>
                            {{/if}}
                            
                            <div class="vpc-gradient"></div>
                            
                            <div class="vpc-content">
                                <div class="vpc-text-wrap">
                                    <h3 class="vpc-title">{{title}}</h3>
                                    <div class="vpc-excerpt">
                                        <p>{{excerpt words="15"}}</p>
                                    </div>
                                </div>
                                <div class="vpc-arrow">
                                    &rarr;
                                </div>
                            </div>
                        </a>
                    {{/foreach}}
                {{else}}
                    {{!-- FALLBACK CARDS --}}
                    <a href="#" class="vnf-program-card">
                        <img src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?q=80&w=600" alt="Scholastic Development" class="vpc-image">
                        <div class="vpc-gradient"></div>
                        <div class="vpc-content">
                            <div class="vpc-text-wrap">
                                <h3 class="vpc-title">Scholastic Development</h3>
                                <div class="vpc-excerpt"><p>Creating Pathways to Lifelong Learning</p></div>
                            </div>
                            <div class="vpc-arrow">&rarr;</div>
                        </div>
                    </a>
                    <a href="#" class="vnf-program-card">
                        <img src="https://images.unsplash.com/photo-1540479859555-17af45c78602?q=80&w=600" alt="Workforce Development" class="vpc-image">
                        <div class="vpc-gradient"></div>
                        <div class="vpc-content">
                            <div class="vpc-text-wrap">
                                <h3 class="vpc-title">Workforce Development</h3>
                                <div class="vpc-excerpt"><p>Equipping youth with practical, industry-relevant skills.</p></div>
                            </div>
                            <div class="vpc-arrow">&rarr;</div>
                        </div>
                    </a>
                    <a href="#" class="vnf-program-card">
                        <img src="https://images.unsplash.com/photo-1576085898323-218337e3e43c?q=80&w=600" alt="Community Engagement" class="vpc-image">
                        <div class="vpc-gradient"></div>
                        <div class="vpc-content">
                            <div class="vpc-text-wrap">
                                <h3 class="vpc-title">Community Engagement</h3>
                                <div class="vpc-excerpt"><p>Distributing wheelchairs and running medical camps.</p></div>
                            </div>
                            <div class="vpc-arrow">&rarr;</div>
                        </div>
                    </a>
                {{/if}}
            {{/get}}
        </div>

        <style>
            .programs-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 2rem;
            }
            @media (max-width: 1024px) {
                .programs-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
            }
            @media (max-width: 600px) {
                .programs-grid {
                    grid-template-columns: 1fr;
                }
            }
            .vnf-program-card {
                position: relative;
                border-radius: 12px;
                overflow: hidden;
                aspect-ratio: 1 / 1.05;
                box-shadow: 0 4px 15px rgba(0,0,0,0.08);
                display: block;
                text-decoration: none !important;
                background-color: #007ec2;
            }
