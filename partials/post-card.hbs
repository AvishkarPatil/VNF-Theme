<article class="post-card {{post_class}}">
    {{#if feature_image}}
    <a href="{{url}}" class="post-card-image-link">
        <div class="post-card-image-wrapper">
            <img class="post-card-image"
                 srcset="{{img_url feature_image size="s"}} 300w,
                         {{img_url feature_image size="m"}} 600w,
                         {{img_url feature_image size="l"}} 1000w"
                 sizes="(max-width: 768px) 300px, 600px"
                 src="{{img_url feature_image size="m"}}"
                 alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                 loading="lazy" />
            {{#if primary_tag}}
                <span class="post-card-primary-tag">{{primary_tag.name}}</span>
            {{/if}}
        </div>
    </a>
    {{/if}}
    <div class="post-card-content">
        <h3 class="post-card-title"><a href="{{url}}">{{title}}</a></h3>
        <div class="post-card-excerpt">
            <p>{{excerpt words="18"}}</p>
        </div>
        <div class="post-card-meta">
            <a href="{{url}}" class="post-card-more">Read story &rarr;</a>
        </div>
    </div>
</article>
