{{!< default}}

{{#post}}
<header class="page-header" style="background-color: var(--color-bg); padding: 4rem 0 1rem; text-align: center; border-bottom: none;">
    <div class="container" style="max-width: 1200px;">
        <span style="display: inline-block; padding: 6px 14px; background: rgba(0, 126, 194, 0.1); color: var(--color-brand); border-radius: 20px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.75rem;">Contact Us</span>
        <h1 class="page-title" style="font-family: var(--font-heading); font-size: clamp(1.8rem, 2.5vw, 2.4rem); color: var(--color-dark); margin: 0; line-height: 1.1; letter-spacing: -0.02em;">{{title}}</h1>
        {{#if custom_excerpt}}
            <p class="page-description" style="font-size: 1.05rem; color: var(--color-text-muted); margin: 1rem auto 0; max-width: 700px; line-height: 1.6;">
                {{custom_excerpt}}
            </p>
        {{else}}
            <p class="page-description" style="font-size: 1.05rem; color: var(--color-text-muted); margin: 1rem auto 0; max-width: 700px; line-height: 1.6;">
                We're here to help and answer any question you might have.
            </p>
        {{/if}}
    </div>
</header>

{{#if feature_image}}
<figure class="page-feature-image global-edge-image" style="width: 100%; margin: 0; display: block; position: relative;">
    <img src="{{img_url feature_image size="xl"}}" alt="{{title}}" style="width: 100%; height: 50vh; min-height: 400px; max-height: 550px; object-fit: cover; display: block;" />
</figure>
{{/if}}

<main id="site-main" class="site-main" style="padding: 2rem 0; background-color: #FAFAFA;">
    <div class="container" style="max-width: 1200px;">

        <div class="contact-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 4rem; align-items: start;">
            
            <!-- Contact Info Sidebar -->
            <div class="contact-info" style="background: #FFF; padding: 2.5rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); border: 1px solid #EAEAEA;">
                <h3 style="font-family: var(--font-heading); color: var(--color-dark); font-size: 1.6rem; margin-top: 0; margin-bottom: 2rem;">Get in Touch</h3>
                
                <p style="margin: 0 0 1.5rem; font-size: 1.05rem; color: #1C1C1C; line-height: 1.6;">
                    <span style="display: block; font-size: 0.85rem; color: #666; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px;">Primary Address</span>
                    Inside ground, Near VK Palace apartment, 10th Main, 2nd Cross, Shankarnagar, Mahalakshmi Layout, Bangalore North, 560086
                </p>

                <p style="margin: 0 0 1.5rem; font-size: 1.05rem; color: #1C1C1C; line-height: 1.6;">
                    <span style="display: block; font-size: 0.85rem; color: #666; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px;">Hessarghatta Office</span>
                    Multi development center #12, near SP Convention Hall, Nada kacheri road, Hessarghatta Bangalore, 560088
                </p>

                <p style="margin: 0 0 1.5rem; font-size: 1.05rem; color: #1C1C1C; line-height: 1.6;">
                    <span style="display: block; font-size: 0.85rem; color: #666; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px;">Email Support</span>
                    <a href="mailto:voiceofneedyfoundation2013@gmail.com" style="color: #007ec2; text-decoration: none; word-break: break-all;">voiceofneedyfoundation2013<br>@gmail.com</a>
                </p>

                <p style="margin: 0 0 1.5rem; font-size: 1.05rem; color: #1C1C1C; line-height: 1.6;">
                    <span style="display: block; font-size: 0.85rem; color: #666; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px;">Direct Phone</span>
                    <span style="white-space: nowrap;"><a href="tel:7411520526" style="color: #007ec2; text-decoration: none;">7411520526</a> &nbsp;|&nbsp; <a href="tel:9019466099" style="color: #007ec2; text-decoration: none;">9019466099</a></span>
                </p>

                <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #EAEAEA;">
                    <span style="display: block; font-size: 0.85rem; color: #666; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 1rem;">Follow Us</span>
                    <div style="display: flex; gap: 0.75rem;">
                        {{#if @custom.facebook_url}}
                        <a href="{{@custom.facebook_url}}" target="_blank" rel="noopener" aria-label="Facebook" style="color: var(--color-dark); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
                        </a>
                        {{/if}}
                        {{#if @custom.twitter_url}}
                        <a href="{{@custom.twitter_url}}" target="_blank" rel="noopener" aria-label="X (Twitter)" style="color: var(--color-dark); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                        </a>
                        {{/if}}
                        {{#if @custom.youtube_url}}
                        <a href="{{@custom.youtube_url}}" target="_blank" rel="noopener" aria-label="YouTube" style="color: var(--color-dark); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                            <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M21.582 6.186a2.6 2.6 0 0 0-1.838-1.839C18.125 3.92 12 3.92 12 3.92s-6.126 0-7.744.427a2.6 2.6 0 0 0-1.838 1.839C2 7.804 2 12 2 12s0 4.197.418 5.815a2.6 2.6 0 0 0 1.838 1.838C5.874 20.08 12 20.08 12 20.08s6.125 0 7.744-.427a2.6 2.6 0 0 0 1.838-1.838C22 16.197 22 12 22 12s0-4.196-.418-5.814zM9.99 15.51v-7.02L15.938 12 9.99 15.51z"></path></svg>
                        </a>
                        {{/if}}
                        {{#if @custom.contact_email}}
                        <a href="mailto:{{@custom.contact_email}}" aria-label="Email" style="color: var(--color-dark); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M2 5.5v13a2.5 2.5 0 0 0 2.5 2.5h15a2.5 2.5 0 0 0 2.5-2.5v-13A2.5 2.5 0 0 0 19.5 3h-15A2.5 2.5 0 0 0 2 5.5zm18 0v2.036l-8 5.454-8-5.454V5.5a.5.5 0 0 1 .5-.5h15a.5.5 0 0 1 .5.5zm-16 13V9.223l7.432 5.068a1 1 0 0 0 1.136 0L20 9.224V18.5a.5.5 0 0 1-.5.5h-15a.5.5 0 0 1-.5-.5z"></path></svg>
                        </a>
                        {{/if}}
                    </div>
                </div>
            </div>
            
            <!-- Contact Form Area -->
            <div class="contact-form" style="background: #FFF; padding: 3rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); border: 1px solid #EAEAEA;">
                <h3 style="font-family: var(--font-heading); color: var(--color-dark); font-size: 2rem; margin-top: 0; margin-bottom: 2rem;">Send a Message</h3>
                <form action="https://formsubmit.co/voiceofneedyfoundation2013@gmail.com" method="POST">
                    <!-- FormSubmit Configuration -->
                    <input type="hidden" name="_subject" value="New Message from VNF Website Contact Form">
                    <input type="hidden" name="_captcha" value="false">
                    <input type="hidden" name="_template" value="table">
                    <input type="text" name="_honey" style="display:none">
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <input type="text" name="Name" placeholder="Your Name" required />
                        <input type="email" name="Email" placeholder="Your Email" required />
                    </div>
                    <input type="text" name="Subject" placeholder="Subject" style="width: 100%; margin-top: 1.5rem;" required />
                    <textarea name="Message" rows="6" placeholder="How can we help you?" style="width: 100%; resize: vertical; margin-top: 1.5rem;" required></textarea>
                    <button type="submit" class="btn btn-primary" style="margin-top: 1.5rem; width: 100%;">Send Message</button>
                </form>
            </div>
            
        </div>
        
        <div class="page-content" style="margin-top: 4rem;">
            {{{content}}}
        </div>
        
    </div>
</main>
{{/post}}
