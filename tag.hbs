{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}

<style>
    .vnf-tag-header { padding: 5rem 0 2rem; }
    @media (max-width: 900px) { .vnf-tag-header { padding: 2rem 0 0.5rem !important; } }
</style>
<header class="page-header vnf-tag-header" style="background-color: var(--color-bg); text-align: center; border-bottom: none;">
    <div class="container" style="max-width: 1200px;">
        {{#tag}}
            <span class="tag-pill" style="display: inline-block; padding: 6px 14px; background: rgba(0, 126, 194, 0.1); color: var(--color-brand); border-radius: 20px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.75rem;">Collection</span>
            <h1 class="page-title" style="font-family: var(--font-heading); font-size: clamp(1.8rem, 2.5vw, 2.4rem); color: var(--color-dark); margin: 0; line-height: 1.1; letter-spacing: -0.02em;">{{name}}</h1>
            {{#if description}}
                <p class="page-description" style="font-size: 1.05rem; color: var(--color-text-muted); max-width: 700px; margin: 1rem auto 0; line-height: 1.6;">
                    {{description}}
                </p>
            {{else}}
                <p class="page-description" style="font-size: 1.05rem; color: var(--color-text-muted); max-width: 700px; margin: 1rem auto 0; line-height: 1.6;">
                    Explore all the latest updates, programs, and success stories related to {{name}}.
                </p>
            {{/if}}
        {{/tag}}
    </div>
</header>

<main id="site-main" class="site-main" style="padding: 2rem 0 4rem; background-color: #FAFAFA;">
    <div class="container" style="max-width: 1200px;">
        
        <div class="post-feed custom-feed-grid" style="display: grid; gap: 2.5rem;">
            <style>
                .custom-feed-grid { grid-template-columns: repeat(3, 1fr) !important; }
                @media (max-width: 1024px) { .custom-feed-grid { grid-template-columns: repeat(2, 1fr) !important; } }
                @media (max-width: 600px) { .custom-feed-grid { grid-template-columns: 1fr !important; } }
                .vnf-mobile-card { height: 400px; }
                @media (max-width: 600px) { .vnf-mobile-card { height: 340px; } }
            </style>
            {{#foreach posts}}
                <a href="{{url}}" class="vnf-post-card vnf-mobile-card" style="position: relative; border-radius: 16px; overflow: hidden; display: block; text-decoration: none; box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: transform 0.3s ease, box-shadow 0.3s ease;">
                    
                    {{#if feature_image}}
                        <img src="{{img_url feature_image size="m"}}" alt="{{title}}" class="vpc-image" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;">
                    {{else}}
                        <div class="vpc-image" style="width: 100%; height: 100%; background-color: #E2E8F0; transition: transform 0.5s ease;"></div>
                    {{/if}}
                    
                    <!-- Blue Gradient Overlay -->
                    <div style="position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,126,194,0) 0%, rgba(0,126,194,0.4) 40%, rgba(0,126,194,0.95) 100%); z-index: 1;"></div>
                    
                    <!-- Content Block -->
                    <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem; z-index: 2; display: flex; flex-direction: column;">
                        <span style="align-self: flex-start; background: rgba(255, 255, 255, 0.2); backdrop-filter: blur(4px); color: #FFF; padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 1rem; border: 1px solid rgba(255,255,255,0.3);">
                            {{#primary_tag}}{{name}}{{/primary_tag}}{{^primary_tag}}Update{{/primary_tag}}
                        </span>
                        
                        <h3 style="font-family: var(--font-heading); font-size: 1.6rem; color: #FFF; margin: 0 0 0.5rem 0; line-height: 1.3;">{{title}}</h3>
                        
                        <div style="display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem;">
                            <p style="font-size: 1.05rem; color: rgba(255, 255, 255, 0.9); line-height: 1.5; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; max-width: 80%;">
                                {{excerpt words="20"}}
                            </p>
                            
                            <div class="vpc-arrow" style="width: 44px; height: 44px; min-width: 44px; border-radius: 50%; background: #FFF; display: flex; align-items: center; justify-content: center; color: #007ec2; font-size: 1.2rem; transform: translateX(0); transition: transform 0.3s ease;">
                                &rarr;
                            </div>
                        </div>
                    </div>
                </a>
            {{/foreach}}
        </div>

        <div class="pagination-wrapper" style="text-align: center; margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #EAEAEA;">
            {{pagination}}
        </div>
        
    </div>
</main>

<style>
/* CSS to make the hover effect work on the tag grid cards exactly like the homepage */
.vnf-post-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0, 126, 194, 0.15); }
.vnf-post-card:hover .vpc-image { transform: scale(1.05); }

/* Fix generic pagination layout */
.pagination { display: flex; align-items: center; justify-content: center; gap: 1rem; margin: 0; padding: 0; font-family: var(--font-body); font-size: 0.95rem; color: #666; }
.pagination .page-number { font-weight: 500; font-size: 0.9rem; letter-spacing: 0.5px; opacity: 0.6; }
.pagination a { display: inline-block; padding: 8px 16px; border-radius: 50px; background: #FFF; border: 1px solid #EAEAEA; color: #1C1C1C; text-decoration: none; font-weight: 600; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; transition: all 0.2s ease; }
.pagination a:hover { background: #007ec2; border-color: #007ec2; color: #FFF; }
</style>
